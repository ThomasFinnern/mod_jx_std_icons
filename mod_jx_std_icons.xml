<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade" version="6.0">
  <name>mod_jx_std_icons</name>
  <creationDate>2026.03.25</creationDate>
  <author>Thomas Finnern</author>
  <authorEmail>mod_jx_std_icons@tomfinnern.de</authorEmail>
  <authorUrl>www.tomfinnern.de</authorUrl>
  <copyright>Copyright (C) 2023-2025 Thomas Finnern All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
  <version>0.7.0.2</version>
  <description>MOD_JX_STD_ICONS_XML_DESCRIPTION</description>
  <scriptfile>install_mod.php</scriptfile>
  <namespace path="src">Finnern\Module\mod_jx_std_icons</namespace>
  <files>
    <filename module="mod_jx_std_icons">mod_jx_std_icons.php</filename>
    <filename>mod_jx_std_icons.xml</filename>
    <filename>changelog.xml</filename>
    <filename>LICENSE</filename>
    <folder>language</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
  </files>
  <!-- css, js, images files, .... -->
  <media folder="media/mod_jx_std_icons" destination="mod_jx_std_icons">
    <folder>css</folder>
  </media>
  <config>
    <fields name="params">
      <fieldset name="basic">
        <field name="isDisplayTablesHeader"
			   type="radio"
			   class="btn-group btn-group-yesno"
			   default="1"
			   label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TABLES_HEADER"
			   description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TABLES_HEADER_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayTechDetail"
			   type="radio"
			   class="btn-group btn-group-yesno"
			   default="1"
			   label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TECH_DETAILS"
			   description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TECH_DETAILS_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayIcomoonTable"
			   type="radio"
			   class="btn-group btn-group-yesno"
			   default="1"
			   label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_ICONMOON_TABLE"
			   description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_ICONMOON_TABLE_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayJoomlaSysIconTable"
			   type="radio"
			   class="btn-group btn-group-yesno"
			   default="1"
			   label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_JOOMLA_SYSTEM_ICON_TABLE"
			   description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_JOOMLA_SYSTEM_ICON_TABLE_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayBrandIconsTable_Awesome"
			   type="radio"
			   class="btn-group btn-group-yesno"
			   default="1"
			   label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_BRAND_ICON_TABLE_AWESOME"
			   description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_BRAND_ICON_TABLE_AWESOME_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="icon_font_size"
			   type="text"
			   label="MOD_JX_STD_ICONS_FIELD_ICON_FONT_SIZE"
			   description="MOD_JX_STD_ICONS_FIELD_ICON_FONT_SIZE_DESC"
			   default="2rem"
		/>
        <field name="name_font_size"
			   type="text"
			   label="MOD_JX_STD_ICONS_FIELD_NAME_FONT_SIZE"
			   description="MOD_JX_STD_ICONS_FIELD_NAME_FONT_SIZE_DESC"
			   default="0.6667rem"
		/>
      </fieldset>
    </fields>
  </config>
  <updateservers>
    <server type="extension" name="J!x Standard Icons Updates">https://raw.githubusercontent.com/ThomasFinnern/mod_jx_std_icons/refs/heads/main/.update/mod_jx_std_icons_update.xml</server>
  </updateservers>
  <changelogurl>https://raw.githubusercontent.com/ThomasFinnern/mod_jx_std_icons/refs/heads/main/changelog.xml</changelogurl>
</extension>
