<?xml version="1.0" encoding="UTF-8"?>
<extension type="module" client="site" method="upgrade" version="6.0">
  <name>mod_jx_std_icons</name>
  <creationDate>2026.04.27</creationDate>
  <author>Thomas Finnern</author>
  <authorEmail>mod_jx_std_icons@tomfinnern.de</authorEmail>
  <authorUrl>www.tomfinnern.de</authorUrl>
  <copyright>Copyright (C) 2023-2025 Thomas Finnern All rights reserved.</copyright>
  <license>GNU General Public License version 2 or later; see LICENSE.txt</license>
  <version>0.7.6</version>
  <description>MOD_JX_STD_ICONS_XML_DESCRIPTION</description>
  <scriptfile>install_mod.php</scriptfile>
  <namespace path="src">Finnern\Module\Jx_std_icons</namespace>
  <files>
    <folder module="mod_jx_std_icons">services</folder>
    <folder>src</folder>
    <folder>tmpl</folder>
    <folder>language</folder>
    <filename>changelog.xml</filename>
    <filename>LICENSE</filename>
  </files>
  <media folder="media/mod_jx_std_icons" destination="mod_jx_std_icons">
    <folder>css</folder>
  </media>
  <help key="MOD__HELP"/>
  <config>
    <fields name="params">
      <fieldset name="basic">
        <field name="isDisplayTablesHeader" type="radio" class="btn-group btn-group-yesno" default="1" label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TABLES_HEADER" description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TABLES_HEADER_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayTechDetail" type="radio" class="btn-group btn-group-yesno" default="1" label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TECH_DETAILS" description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_TECH_DETAILS_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayIcomoonTable" type="radio" class="btn-group btn-group-yesno" default="1" label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_ICONMOON_TABLE" description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_ICONMOON_TABLE_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayJoomlaSysIconTable" type="radio" class="btn-group btn-group-yesno" default="1" label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_JOOMLA_SYSTEM_ICON_TABLE" description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_JOOMLA_SYSTEM_ICON_TABLE_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
        <field name="isDisplayBrandIconsTable_Awesome" type="radio" class="btn-group btn-group-yesno" default="1" label="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_BRAND_ICON_TABLE_AWESOME" description="MOD_JX_STD_ICONS_FIELD_IS_DISPLAY_BRAND_ICON_TABLE_AWESOME_DESC">
          <option value="0">JNO</option>
          <option value="1">JYES</option>
        </field>
      </fieldset>
      <fieldset name="advanced" label="MOD_JX_STD_ICONS_FIELDSET_STYLE">
        <field name="layout" type="modulelayout" class="form-select" validate="moduleLayout" label="JFIELD_ALT_LAYOUT_LABEL" description="JFIELD_ALT_MODULE_LAYOUT_DESC"/>
        <field name="icon_font_size" type="text" label="MOD_JX_STD_ICONS_FIELD_ICON_FONT_SIZE" description="MOD_JX_STD_ICONS_FIELD_ICON_FONT_SIZE_DESC" default="2rem"/>
        <field name="name_font_size" type="text" label="MOD_JX_STD_ICONS_FIELD_NAME_FONT_SIZE" description="MOD_JX_STD_ICONS_FIELD_NAME_FONT_SIZE_DESC" default="1em"/>
        <field name="icon_color" type="color" label="MOD_JX_STD_ICONS_FIELD_ICON_COLOR" description="MOD_JX_STD_ICONS_FIELD_ICON_COLORDESC" default="rgb(0, 71, 171)" format="rgb"/>
        <field name="name_color" type="color" label="MOD_JX_STD_ICONS_FIELD_NAME_FONT_COLOR" description="MOD_JX_STD_ICONS_FIELD_NAME_FONT_COLOR_DESC" default="rgb(71,98,133)" format="rgb"/>
        <field name="moduleclass_sfx" type="text" label="COM_MODULES_FIELD_MODULECLASS_SFX_LABEL"/>
        <field name="custom_css" type="textarea" filter="\Joomla\CMS\Component\ComponentHelper::filterText" label="MOD_DPMEDIA_GALLERY_FIELD_CUSTOM_CSS_LABEL" description="MOD_DPMEDIA_GALLERY_FIELD_CUSTOM_CSS_DESC"/>
      </fieldset>
    </fields>
  </config>
  <updateservers>
    <server type="extension" name="J!x Standard Icons Updates">
			https://raw.githubusercontent.com/ThomasFinnern/mod_jx_std_icons/refs/heads/main/.update/mod_jx_std_icons_update.xml
		</server>
  </updateservers>
  <changelogurl>https://raw.githubusercontent.com/ThomasFinnern/mod_jx_std_icons/refs/heads/main/changelog.xml
	</changelogurl>
</extension>
